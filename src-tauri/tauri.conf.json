{
  "$schema": "../node_modules/@tauri-apps/cli/tauri.schema.json",
  "productName": "CARAKA Desktop",
  "version": "0.1.0",
  "identifier": "com.caraka.desktop",
  "build": {
    "beforeDevCommand": "npx --yes serve src -l 1420",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "CARAKA Desktop — Secure Mesh Communication",
        "width": 1200,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
