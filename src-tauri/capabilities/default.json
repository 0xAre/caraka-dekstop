{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability default untuk CARAKA Desktop — izinkan semua IPC commands dan event system",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:event:allow-emit",
    "core:window:default",
    "core:app:default",
    "shell:allow-open"
  ]
}
